# Telegram API Credentials (from my.telegram.org)
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Comma-separated list of Telegram Channel/Group IDs to monitor
TELEGRAM_CHANNELS=-100xxxxxxx,-100xxxxxxx

# PostgreSQL Database Credentials
DB_HOST=your_db_host_here
DB_PORT=5432
DB_USER=your_db_user_here
DB_NAME=your_db_name_here
DB_PASSWORD=your_db_password_here

# Optional — enables live AI Research tab synthesis in main.py (dashboard side only)
GEMINI_API_KEY=your_gemini_api_key_here

# BloFin API credentials (blofin.com -> Assets -> API Management).
# Grant Read + Trade permissions only — leave Transfer off. Restrict to your
# server's IP if BloFin offers it.
BLOFIN_API_KEY=your_blofin_api_key_here
BLOFIN_API_SECRET=your_blofin_api_secret_here
BLOFIN_API_PASSPHRASE=your_blofin_api_passphrase_here

# Safety switches for the auto-trader (scraper.py's consolidation loop):
# - BLOFIN_DRY_RUN=true (default): computes and logs every auto-trade
#   decision to the blofin_trades table WITHOUT sending a real order.
#   Verify the dashboard's Account tab / logs look right before flipping
#   this to "false" to actually go live.
# - BLOFIN_SANDBOX=true: points at BloFin's demo-trading environment
#   (fake balance, same API) instead of your real live account. Useful for
#   testing the full order-placement path with zero real-money risk before
#   trusting BLOFIN_DRY_RUN=false against your live account.
BLOFIN_DRY_RUN=true
BLOFIN_SANDBOX=false
